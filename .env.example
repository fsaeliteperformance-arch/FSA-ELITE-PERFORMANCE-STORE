# Stripe keys — obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Full origin URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DNSSEC DS record — obtain from your DNS provider (e.g. Cloudflare dashboard →
# DNS → DNSSEC, or AWS Route 53 → Hosted zone → DNSSEC signing).
# Enter these values in the Ionos control panel under:
#   Domains & SSL → <your domain> → DNS → DNSSEC
DNSSEC_KEY_TAG=
DNSSEC_ALGORITHM=
DNSSEC_DIGEST_TYPE=
DNSSEC_DIGEST=
