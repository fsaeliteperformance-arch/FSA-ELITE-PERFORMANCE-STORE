# Stripe keys — obtain from https://dashboard.stripe.com/apikeys
# Store this in .env.local only (never commit or expose to the client)
STRIPE_SECRET_KEY=sk_test_...

# Publishable key is safe for the client bundle
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---------------------------------------------------------------------------
# Domain configuration
#
# This app serves two public domains from a single Next.js deployment:
#   • Store    — NEXT_PUBLIC_SITE_URL     (e.g. https://store.fsaeliteperformance.com)
#   • Training — NEXT_PUBLIC_TRAINING_URL (e.g. https://training.fsaeliteperformance.com)
#
# In production set both variables to the real public URLs (no trailing slash).
# In local development you can run two `next dev` ports and point each variable
# at the appropriate port (e.g. http://localhost:3000 / http://localhost:3001).
#
# The middleware reads NEXT_PUBLIC_TRAINING_URL to determine which incoming
# hostname should be rewritten to the /training/* routes.
# ---------------------------------------------------------------------------

# Full URL of the FSA Elite merchandise store (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Full URL of the FSA Elite training portal (no trailing slash)
NEXT_PUBLIC_TRAINING_URL=http://localhost:3001

# Optional bind token for /api/bind
BIND_TOKEN=dywo2TUV7qCR7Gm8Q9ZwPp

# DNSSEC DS record — obtain from your DNS provider (e.g. Cloudflare dashboard →
# DNS → DNSSEC, or AWS Route 53 → Hosted zone → DNSSEC signing).
# DNSSEC_KEY_TAG=
# DNSSEC_ALGORITHM=
# DNSSEC_DIGEST_TYPE=
# DNSSEC_DIGEST=
